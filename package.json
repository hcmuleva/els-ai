{
  "name": "els-ai",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "backend/gateway",
    "backend/auth-service",
    "backend/quiz-service",
    "backend/ai-service"
  ],
  "scripts": {
